{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".calx/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".calx/hooks/orientation-gate.sh"
          },
          {
            "type": "command",
            "command": ".calx/hooks/collapse-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".calx/hooks/session-end.sh"
          }
        ]
      }
    ]
  }
}
